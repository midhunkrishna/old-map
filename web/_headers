# Cloudflare Pages headers. Cloudflare serves .wasm as application/wasm and
# auto-compresses text responses (json/js/geojson) at the edge.

# Immutable engine + grid: safe to cache hard until the next deploy reuploads.
/oldmap.wasm
  Cache-Control: public, max-age=86400
/grid.bin
  Cache-Control: public, max-age=86400

# Precomputed isochrones and map data rarely change.
/iso/*
  Cache-Control: public, max-age=86400
/data/*
  Cache-Control: public, max-age=86400

# Diorama ambience recordings (CC0, see /audio/CREDITS.md) change only on deploy.
/audio/*
  Cache-Control: public, max-age=86400
